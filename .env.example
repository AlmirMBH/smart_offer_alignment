DATABASE_ENGINE=sqlite
SQLITE_DATABASE_PATH=./app.db

# PostgreSQL (set DATABASE_ENGINE=postgresql and fill in):
# DATABASE_ENGINE=postgresql
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=cda_mlrp
# POSTGRES_USER=cda_user
# POSTGRES_PASSWORD=your_password

EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
PRICE_IMPUTATION_MODEL=paraphrase-multilingual-MiniLM-L12-v2
PREFERRED_WEBSITES=https://www.emajstor.hr/cijene/vodoinstalacije
SIMILARITY_THRESHOLD=0.85
ITEM_SIMILARITY_THRESHOLD_PRICING=0.85
PRICING_SIMILARITY_THRESHOLD=20
SHEET_SIMILARITY_THRESHOLD=0.75
AUTO_APPROVE_PRICES=false
PRICE_APPROVALS_PAGE_SIZE=6
